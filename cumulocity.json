{
  "apiVersion": "2",
  "name": "gainsight-sync-ms",
  "version": "0.1.7",
  "provider": {
    "name": "Cumulocity"
  },
  "isolation": "PER_TENANT",
  "roles": [
    "ROLE_GAINSIGHT_READ"
  ],
  "requiredRoles": [
    "ROLE_OPTION_MANAGEMENT_READ",
    "ROLE_OPTION_MANAGEMENT_ADMIN",
    "ROLE_APPLICATION_MANAGEMENT_READ",
    "ROLE_APPLICATION_MANAGEMENT_ADMIN"
  ],
  "livenessProbe": {
    "httpGet": {
      "path": "/health",
      "port": 80
    },
    "initialDelaySeconds": 30,
    "periodSeconds": 60
  },
  "readinessProbe": {
    "httpGet": {
      "path": "/health",
      "port": 80
    },
    "initialDelaySeconds": 10,
    "periodSeconds": 10
  }
}
