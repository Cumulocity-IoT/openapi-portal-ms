{
  "name": "openapi-portal-ms",
  "version": "1.0.0",
  "description": "Generic Cumulocity microservice that hosts and renders multiple OpenAPI specs (Redoc + Swagger UI).",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "prebuild": "rimraf dist && rimraf .tmp",
    "build": "nest build",
    "build:image": "bash ./scripts/build.sh",
    "docker:run": "docker run -it -p 80:80 --name openapi-portal-ms --env-file .env openapi-portal-ms:local",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "DEV_MODE=true nest start --watch",
    "start:debug": "DEV_MODE=true nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint . --fix",
    "lint:ci": "eslint .",
    "test": "jest",
    "test:ci": "jest --ci --runInBand --forceExit --reporters=default --reporters=github-actions",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "docs:build": "bash ./scripts/build-docs.sh",
    "openapi:generate": "GENERATE_API_DOCS=true nest start",
    "openapi:html": "npx @redocly/cli build-docs ./docs/openapi.json -o ./docs/index.html"
  },
  "dependencies": {
    "@c8y/client": "^1023.68.3",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.3.0",
    "dotenv": "^17.4.2",
    "http-proxy-middleware": "^3.0.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@redocly/cli": "^2.28.0",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20.19.39",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "jest-github-actions-reporter": "^1.0.3",
    "prettier": "^3.8.3",
    "rimraf": "6.0.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "tsconfig.spec.json" }]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
